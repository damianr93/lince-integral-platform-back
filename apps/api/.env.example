# ── Base de datos PostgreSQL ───────────────────────────────────────────────
# Railway lo genera automáticamente al agregar el plugin PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_REFRESH_SECRET=cambia-esto-por-otro-secreto-diferente

# ── CORS ───────────────────────────────────────────────────────────────────
# Dominio de tu frontend en Netlify (sin trailing slash)
ALLOWED_ORIGINS=https://tu-app.netlify.app

# ── App ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Schema sync ────────────────────────────────────────────────────────────
# Poner "true" SOLO en el primer deploy para crear las tablas.
# Cambiar a "false" o eliminar después del primer deploy exitoso.
DB_SYNCHRONIZE=true

# ── CRM — MongoDB ──────────────────────────────────────────────────────────
CRM_MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/lince-crm

# ── CRM ────────────────────────────────────────────────────────────────────
CRM_ADVISORS=EZEQUIEL,DENIS,MARTIN
EXTERNAL_FIXED_TOKEN=cambia-esto-por-un-token-secreto
FOLLOW_UP_AUTOMATION_ENABLED=false

# ── CRM — Emails por asesor ────────────────────────────────────────────────
CRM_ADVISOR_EZEQUIEL_EMAIL=
CRM_ADVISOR_DENIS_EMAIL=
CRM_ADVISOR_MARTIN_EMAIL=
CRM_ADVISOR_SIN_ASIGNAR_EMAIL=
CRM_ADVISOR_DEFAULT_EMAIL=

# ── SMTP ───────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAILER_HOST=
MAILER_PORT=587
MAILER_SECURE=false
MAILER_EMAIL=
MAILER_SECRET_KEY=

# ── YCloud WhatsApp (módulo Campañas Marketing) ────────────────────────────
YCLOUD_API_KEY=
# ID del número de WhatsApp Business de cada asesor en YCloud
YCLOUD_PHONE_ID_EZEQUIEL=
YCLOUD_PHONE_ID_DENIS=
YCLOUD_PHONE_ID_MARTIN=
# Secret del endpoint de webhook (Developers → Webhook en el panel de YCloud)
YCLOUD_WEBHOOK_SECRET=

# ── OCR — AWS S3 ──────────────────────────────────────────────────────────
# Crear un bucket S3 privado y una IAM user con política mínima:
#   s3:PutObject, s3:GetObject, s3:DeleteObject en arn:aws:s3:::BUCKET_NAME/*
# Documentación: https://docs.aws.amazon.com/AmazonS3/latest/userguide/creating-bucket.html
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=lince-ocr-docs
AWS_REGION=us-east-1

# ── OCR — Google Cloud Vision API ─────────────────────────────────────────
# Opción A (Railway / producción): pegar el JSON completo del service account
#   1. Crear proyecto en Google Cloud Console
#   2. Habilitar "Cloud Vision API"
#   3. Crear Service Account con rol "Cloud Vision API User"
#   4. Descargar clave JSON y pegar su contenido aquí (todo en una línea)
#   Docs: https://cloud.google.com/vision/docs/setup
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Opción B (dev local): path al archivo JSON del service account
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/al/service-account.json

# Opción C (solo para pruebas rápidas — funcionalidad limitada):
# GOOGLE_VISION_API_KEY=AIzaSy...

# ── OCR — Notificaciones SMTP ─────────────────────────────────────────────
# Servidor SMTP para emails de alerta OCR (puede ser Donweb, Gmail, etc.)
OCR_SMTP_HOST=
OCR_SMTP_PORT=587
# "true" para SSL (puerto 465), "false" para STARTTLS (puerto 587)
OCR_SMTP_SECURE=false
OCR_SMTP_USER=
OCR_SMTP_PASS=
# Dirección "De" en los emails enviados por el módulo OCR
OCR_MAIL_FROM=Sistema OCR <ocr@empresa.com>
# Email del equipo ADMIN que recibe alertas de documentos con errores
OCR_ADMIN_EMAIL=
